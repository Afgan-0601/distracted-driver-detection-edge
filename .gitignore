# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
env/
venv/
ENV/

# ── Dataset — never commit raw images ────────────────────────────────────────
data/raw/imgs/
data/raw/*.zip
data/raw/*.csv
data/processed/

# ── Model weights — too large for git, use Git LFS or Drive ──────────────────
models/weights/*.pt
models/weights/*.onnx
models/weights/*.torchscript.pt
models/weights/training_history.json
# Keep the directory itself
!models/weights/.gitkeep

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Docker ────────────────────────────────────────────────────────────────────
*.log

# ── Frontend (Vite/Node) ─────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# ── Environment / local secrets ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node / package manager noise ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Tooling caches / coverage ─────────────────────────────────────────────────
.eslintcache
.npm/
.pnpm-store/
.parcel-cache/
coverage/
frontend/coverage/

# ── Local temp/editor swap files ───────────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
*.local
